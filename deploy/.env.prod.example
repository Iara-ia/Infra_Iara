# IARA — variáveis do deploy bootstrap. Copie para .env.prod e preencha.
# NUNCA versione o .env.prod (já está no .gitignore).

# ===== Postgres (serviço do compose) =====
POSTGRES_USER=iara
POSTGRES_PASSWORD=TROQUE-esta-senha-forte
POSTGRES_DB=iara

# ===== Back (API + Worker) =====
# host = nome do serviço do compose (postgres / redis)
DATABASE_URL=postgresql://iara:TROQUE-esta-senha-forte@postgres:5432/iara?schema=public
REDIS_URL=redis://redis:6379
API_PORT=3333
API_BASE_URL=https://SEU-DOMINIO            # usado em links (afiliados, /storage local)
TOKEN_ENC_KEY=TROQUE-por-uma-chave-aleatoria-de-32+caracteres

# Providers — comece em mock; ligue o real quando tiver a chave (sem mexer no código)
PROVIDER_LLM=mock            # claude
PROVIDER_IMAGE=mock          # flux
PROVIDER_DISTRIBUTION=mock   # ayrshare | meta (publicador direto — quando existir)
PROVIDER_SAFETY=mock         # real
PROVIDER_CONSISTENCY=mock    # real
PROVIDER_BILLING=mock        # stripe

ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=
AYRSHARE_API_KEY=

# Storage: local (disco do container) | s3 | r2
# local = mais simples e grátis, MAS some se recriar o container sem volume.
# r2/s3 = durável (recomendado): preencha abaixo e instale @aws-sdk/client-s3 no back.
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=                  # R2: https://<accountid>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=      # CDN/bucket público da mídia

# Auth: dev (header x-user-id, ok p/ operar só você) | clerk
AUTH_PROVIDER=dev
CLERK_SECRET_KEY=

# Guardrail de custo
COST_LIMIT_PERSONA_DAILY_BRL=50

# ===== Front (painel) — EMBUTIDOS NO BUILD =====
NEXT_PUBLIC_API_BASE_URL=https://api.SEU-DOMINIO   # a API vista pelo NAVEGADOR (público)
NEXT_PUBLIC_DEV_USER_ID=user_fundador_seed
